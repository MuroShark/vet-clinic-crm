# Скопируйте в .env и заполните реальными значениями (.env не коммитить в git!)

# Домен приложения (A-запись должна указывать на IP сервера)
DOMAIN=your-domain.example.com

# Email для уведомлений Let's Encrypt
CERTBOT_EMAIL=admin@example.com

# Пароль SA для MS SQL Server (минимум 8 символов, буквы + цифры + спецсимвол)
SA_PASSWORD=Change_Me_Strong!Pass1

# Секретный ключ подписи JWT — сгенерируйте случайный:
# openssl rand -base64 48
JWT_KEY=REPLACE_WITH_RANDOM_64_CHAR_SECRET
